# Application
APP_ENV=development
APP_DEBUG=1
APP_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=taskpilot
DB_USER=taskpilot
DB_PASS=change_me

# Security and sessions
PASSWORD_MIN_LENGTH=10
SESSION_LIFETIME=86400
SESSION_IDLE_TIMEOUT=1800
SESSION_REGENERATE_INTERVAL=900
MAX_JSON_BYTES=1048576
SECURITY_LOG_FILE=/tmp/taskpilot-security.log

# Rate limits
RATE_LIMIT_GENERAL=120
RATE_LIMIT_GENERAL_WINDOW=60
RATE_LIMIT_READ=240
RATE_LIMIT_READ_WINDOW=60
RATE_LIMIT_AUTH=10
RATE_LIMIT_AUTH_WINDOW=600
RATE_LIMIT_PUBLIC=60
RATE_LIMIT_PUBLIC_WINDOW=60
